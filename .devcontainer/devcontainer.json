{
 "name": "cityjson-rs",
 "build": {
  "dockerfile": "Dockerfile"
 },
 "features": {
  "ghcr.io/balazsdukai/devcontainer-tools/tools:1": {}
 },
 "mounts": [
  {
   "source": "devcontainer-cargo-cache-${devcontainerId}",
   "target": "/usr/local/cargo",
   "type": "volume"
  },
  {
   "source": "${localWorkspaceFolder}/../cityjson-corpus",
   "target": "${containerWorkspaceFolder}/../cityjson-corpus",
   "type": "bind"
  }
 ],
 "postCreateCommand": "rustc --version && uv --version && cbindgen --version && jq --version",
 "customizations": {
  "jetbrains": {
   "backend": "RustRover"
  }
 },
 "containerEnv": {
  "CITYJSON_SHARED_CORPUS_ROOT": "${containerWorkspaceFolder}/../cityjson-corpus"
 }
}
