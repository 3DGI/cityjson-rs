{
  "name": "cityjson-rs-docs-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:api && astro build",
    "preview": "astro preview --host 127.0.0.1",
    "check": "npm run generate:api && npm run validate:symbols && astro check && astro build",
    "test": "playwright test",
    "generate:api": "node ./src/scripts/generate-api-reference.mjs",
    "validate:symbols": "node ./src/scripts/validate-symbols.mjs"
  },
  "dependencies": {
    "@astrojs/starlight": "latest",
    "astro": "latest",
    "@astrojs/mdx": "latest"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@playwright/test": "latest",
    "typescript": "latest"
  }
}
