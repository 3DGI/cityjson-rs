#!/usr/bin/env just --justfile

_default:
    just --list

# Build the shared FFI core crate.
ffi-build:
    ./tools/ffi.sh build core

# Run the shared FFI core crate tests.
ffi-test:
    ./tools/ffi.sh test

# Run the shared FFI validation pipeline.
ffi:
    ./tools/ffi.sh test

# Fast compile-time validation for library, binary, and test targets.
check:
    cargo check -p cityjson-index --lib --bin cjindex --tests --target-dir target

# Build the production binary.
build *args:
    cargo build -p cityjson-index --bin cjindex --target-dir target {{args}}

clean:
    ./tools/ffi.sh clean

# Run clippy with the project's strict lint settings.
lint:
    cargo clippy -p cityjson-index --lib --bin cjindex --tests --target-dir target

# Format this workspace with rustfmt without traversing sibling path dependencies.
fmt:
    cargo fmt -p cityjson-index -p cityjson-index-ffi-core

# Check rustfmt without traversing sibling path dependencies.
fmt-check:
    cargo fmt -p cityjson-index -p cityjson-index-ffi-core -- --check

# Run the library and integration tests.
test:
    cargo test -p cityjson-index --lib --bin cjindex --tests --target-dir target

# Run the benchmark harness with human-readable output.
bench-index *args:
    cargo run --release -p cityjson-index --bin bench-index --target-dir target -- {{args}}

# Run the benchmark harness with JSON output.
bench-index-json *args:
    cargo run --release -p cityjson-index --bin bench-index --target-dir target -- --json {{args}}

# Build the shared library and run the Python install smoke tests through tox and tox-uv.
test-python:
    ./tools/ffi.sh test python

# Build API docs for all features without pulling in dependencies.
doc:
    cargo doc --all-features --no-deps --target-dir target

# Build the Python bindings wheel.
build-python:
    ./tools/ffi.sh build python

# Run the release-quality validation pipeline.
ci:
    just fmt-check
    just check
    just lint
    just test
    just ffi
    just test-python
    just doc
